generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  role       Role      @default(CONSUMER)
  isApproved Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  projects   Project[]
  reviews    Review[]
  inquiries  Inquiry[]
}

model Provider {
  id                String           @id @default(uuid())
  businessName      String
  ownerName         String
  email             String           @unique
  password          String
  phone             String
  category          String
  experience        Int              @default(0)
  isVerified        Boolean          @default(false)
  isRejected        Boolean          @default(false)
  address           String?
  bio               String?
  aadharCard        String?
  panCard           String?
  profileImage      String?
  profileCompletion Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  portfolioImages   PortfolioImage[]
  quotes            Quote[]
  reviews           Review[]
  products          Product[]
  inquiries         Inquiry[]
}

model PortfolioImage {
  id          String   @id @default(uuid())
  providerId  String
  title       String
  description String?
  imageData   String
  createdAt   DateTime @default(now())
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model Project {
  id           String   @id @default(uuid())
  userId       String
  title        String
  type         String
  location     String
  plotSize     Float
  budget       Float
  timeline     String
  currentStage String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User            @relation(fields: [userId], references: [id])
  quotes       Quote[]
  updates      ProjectUpdate[]
  tasks        ProjectTask[]
  reviews      Review[]
}

model Quote {
  id            String   @id @default(uuid())
  projectId     String
  providerId    String
  estimatedCost Float
  timeline      String
  notes         String
  isAccepted    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id])
  provider      Provider @relation(fields: [providerId], references: [id])
}

enum Role {
  ADMIN
  CONSUMER
}

model ProjectUpdate {
  id        String   @id @default(uuid())
  projectId String
  title     String
  status    String   // e.g. "In Progress", "Completed", "Milestone Reached"
  notes     String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  providerId String
  userId     String
  projectId  String?
  rating     Int      // 1 to 5 stars
  comment    String
  createdAt  DateTime @default(now())
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model ProjectTask {
  id               String   @id @default(uuid())
  projectId        String
  stage            String   // e.g. "Land & Legal", "Design & Planning"
  title            String   // e.g. "Soil testing", "Excavation"
  duration         Int      // duration in days
  status           String   // "Todo", "In Progress", "Completed"
  photoUrl         String?  // base64 image showing work completion
  materialName     String?  // name of material used e.g. Cement, Bricks
  materialQuantity Int?     // number of units used
  materialUnitCost Float?   // cost per unit
  taskCost         Float?   @default(0.0) // total spent on this task/material
  quotedCost       Float?   @default(0.0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  text       String
  createdAt  DateTime @default(now())
}

model Product {
  id             String    @id @default(uuid())
  providerId     String
  categoryId     Int?
  category       String?
  name           String
  description    String
  specifications String?
  images         String[]
  status         String    @default("Approved") // "Pending", "Approved", "Rejected"
  rejectedReason String?
  pricePerUnit   Float     @default(0.0)
  unitType       String    @default("Bag")
  costPrice      Float     @default(0.0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  provider       Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  inquiries      Inquiry[]
}

model Inquiry {
  id             String             @id @default(uuid())
  buyerId        String
  providerId     String
  productId      String?
  title          String
  description    String
  quantity       Float
  unit           String
  location       String
  images         String[]
  status         String             @default("New") // "New", "Viewed", "Contacted", "Closed", "Accepted", "Rejected"
  quotedPrice    Float?
  deliveryStatus String             @default("Pending")
  gstPercent     Float              @default(18.0)
  rating         Int?
  reviewText     String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  buyer          User               @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  provider       Provider           @relation(fields: [providerId], references: [id], onDelete: Cascade)
  product        Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  statusLogs     InquiryStatusLog[]
}

model InquiryStatusLog {
  id              String   @id @default(uuid())
  inquiryId       String
  status          String
  notes           String?
  changedByUserId String?
  createdAt       DateTime @default(now())
  inquiry         Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
}

model MaterialNews {
  id          String   @id @default(uuid())
  title       String
  content     String
  category    String?
  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
